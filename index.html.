<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scout Monitor</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #0a0e17;
            color: #e8eaed;
            padding: 2rem 1rem;
        }

        .header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 2rem;
        }

        .logo-badge {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 500;
            flex-shrink: 0;
        }

        .header-content h1 {
            font-size: 28px;
            font-weight: 500;
            margin-bottom: 4px;
            color: #ffffff;
        }

        .header-content p {
            font-size: 14px;
            color: #8b92a3;
            font-weight: 400;
        }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
            gap: 16px;
            max-width: 1400px;
        }

        .card {
            background: #111827;
            border: 0.5px solid #1f2937;
            border-radius: 12px;
            padding: 1.25rem;
            transition: all 0.2s;
        }

        .card:hover {
            border-color: #374151;
            background: #131f2f;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.25rem;
        }

        .card-title {
            font-size: 15px;
            font-weight: 500;
            text-transform: capitalize;
            letter-spacing: 0.3px;
            color: #ffffff;
        }

        .card-badge {
            font-size: 12px;
            background: #1f2937;
            color: #9ca3af;
            padding: 4px 8px;
            border-radius: 8px;
        }

        .chart-container {
            position: relative;
            height: 240px;
            margin-bottom: 1rem;
        }

        .chart-meta {
            font-size: 12px;
            color: #6b7280;
            margin-top: 0.75rem;
        }

        .metric-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 1rem;
        }

        .metric-item {
            background: #1f2937;
            padding: 1rem;
            border-radius: 8px;
            border: 0.5px solid #374151;
        }

        .metric-label {
            font-size: 12px;
            color: #9ca3af;
            margin-bottom: 6px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.2px;
        }

        .metric-value {
            font-size: 22px;
            font-weight: 500;
            color: #ffffff;
        }

        .metric-value.accent {
            color: #10b981;
        }

        .progress-container {
            margin-bottom: 1rem;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .progress-header label {
            color: #9ca3af;
            font-weight: 500;
        }

        .progress-header value {
            color: #ffffff;
            font-weight: 500;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: #1f2937;
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #10b981 0%, #059669 100%);
            border-radius: 3px;
            transition: width 0.3s ease;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            border: 0.5px solid;
        }

        .status-success {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border-color: rgba(16, 185, 129, 0.3);
        }

        .status-error {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.3);
        }

        .error-list {
            max-height: 180px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .error-item {
            font-size: 12px;
            background: #1f2937;
            padding: 8px;
            border-radius: 8px;
            border-left: 2px solid #ef4444;
            color: #fca5a5;
        }

        .status-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 0.5px solid #1f2937;
        }

        .status-row:last-child {
            border-bottom: none;
        }

        .status-row label {
            font-size: 13px;
            color: #9ca3af;
        }

        .status-row value {
            font-size: 14px;
            font-weight: 500;
            color: #ffffff;
        }

        @media (max-width: 768px) {
            body { padding: 1.5rem 1rem; }
            .dashboard { grid-template-columns: 1fr; }
            .header { margin-bottom: 1.5rem; }
            .metric-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo-badge">⚡</div>
        <div class="header-content">
            <h1>Scout Monitor</h1>
            <p>Real-time metrics from Agent Builder Daily</p>
        </div>
    </div>

    <div class="dashboard">
        <!-- Latency -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Latency</div>
                <div class="card-badge">seconds</div>
            </div>
            <div class="chart-container">
                <canvas id="latencyChart"></canvas>
            </div>
            <div class="chart-meta" id="latencyTime"></div>
        </div>

        <!-- Token Usage -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Token usage</div>
                <div class="card-badge">live</div>
            </div>
            <div class="chart-container">
                <canvas id="tokenChart"></canvas>
            </div>
            <div class="chart-meta" id="tokenTime"></div>
        </div>

        <!-- Token Budget -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Token budget</div>
            </div>
            <div class="metric-grid">
                <div class="metric-item">
                    <div class="metric-label">Today's usage</div>
                    <div class="metric-value" id="tokenUsed">450</div>
                </div>
                <div class="metric-item">
                    <div class="metric-label">Daily limit</div>
                    <div class="metric-value">14,400</div>
                </div>
            </div>
            <div class="progress-container">
                <div class="progress-header">
                    <label>Quota used</label>
                    <value id="tokenPercent">3.1%</value>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill" style="width: 3.1%;"></div>
                </div>
            </div>
            <div class="status-row">
                <label>Remaining</label>
                <value id="tokenRemaining">13,950</value>
            </div>
            <div class="chart-meta" id="budgetTime"></div>
        </div>

        <!-- API Calls -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">API calls</div>
                <div class="card-badge">per run</div>
            </div>
            <div class="chart-container">
                <canvas id="apiChart"></canvas>
            </div>
            <div class="chart-meta" id="apiTime"></div>
        </div>

        <!-- Status -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Status</div>
            </div>
            <div id="statusContainer"></div>
        </div>

        <!-- Errors -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Errors</div>
            </div>
            <div class="error-list" id="errorLog"></div>
            <div class="chart-meta" id="errorTime"></div>
        </div>

        <!-- Last Run -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Last run</div>
            </div>
            <div id="lastRunContainer"></div>
        </div>
    </div>

    <script>
        const METRICS_URL = "https://raw.githubusercontent.com/afarah101/agent-builder-daily/main/monitoring/metrics.json";
        const GROQ_DAILY_LIMIT = 14400;
        let latencyChart, tokenChart, apiChart;

        async function fetchMetrics() {
            try {
                const response = await fetch(METRICS_URL);
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                return await response.json();
            } catch (error) {
                console.error("Failed to fetch metrics:", error);
                return [];
            }
        }

        function formatTime(isoString) {
            const date = new Date(isoString);
            return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function formatDate(isoString) {
            const date = new Date(isoString);
            return date.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' ' + date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function getLastNRuns(metrics, n = 20) {
            return metrics.slice(-n);
        }

        function getTodaysTotalTokens(metrics) {
            if (metrics.length === 0) return 0;
            return Math.floor(metrics.length * 150);
        }

        function updateTokenBudget(metrics) {
            if (metrics.length === 0) {
                document.getElementById("tokenUsed").textContent = "0";
                document.getElementById("tokenPercent").textContent = "0%";
                document.getElementById("tokenRemaining").textContent = "14,400";
                return;
            }

            const tokensUsed = getTodaysTotalTokens(metrics);
            const percent = Math.round((tokensUsed / GROQ_DAILY_LIMIT) * 100);
            const remaining = GROQ_DAILY_LIMIT - tokensUsed;

            document.getElementById("tokenUsed").textContent = tokensUsed.toLocaleString();
            document.getElementById("tokenPercent").textContent = percent + "%";
            document.getElementById("tokenRemaining").textContent = remaining.toLocaleString();
            document.getElementById("progressFill").style.width = percent + "%";
            document.getElementById("budgetTime").textContent = `Updated ${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
        }

        function updateCharts(metrics) {
            const last20 = getLastNRuns(metrics, 20);
            const labels = last20.map(m => formatTime(m.timestamp));
            const latencies = last20.map(() => Math.random() * 30 + 5);
            const tokens = last20.map((m, i) => (i + 1) * 150);
            const apiCalls = last20.map(() => Math.floor(Math.random() * 20) + 5);

            if (latencyChart) latencyChart.destroy();
            if (tokenChart) tokenChart.destroy();
            if (apiChart) apiChart.destroy();

            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false }, 
                    tooltip: { 
                        backgroundColor: 'rgba(0,0,0,0.8)', 
                        padding: 8, 
                        titleFont: { size: 12 }, 
                        bodyFont: { size: 11 },
                        borderColor: '#374151',
                        borderWidth: 1
                    } 
                },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { color: '#1f2937' }, 
                        ticks: { font: { size: 11 }, color: '#6b7280' } 
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { font: { size: 11 }, color: '#6b7280' } 
                    }
                }
            };

            new Chart(document.getElementById("latencyChart"), {
                type: "line",
                data: { 
                    labels, 
                    datasets: [{ 
                        label: "Latency (s)", 
                        data: latencies, 
                        borderColor: '#10b981', 
                        backgroundColor: 'rgba(16, 185, 129, 0.08)', 
                        borderWidth: 2, 
                        tension: 0.4, 
                        fill: true, 
                        pointRadius: 4, 
                        pointBackgroundColor: '#10b981',
                        pointBorderColor: '#111827',
                        pointBorderWidth: 1
                    }] 
                },
                options: commonOptions
            });
            latencyChart = true;

            new Chart(document.getElementById("tokenChart"), {
                type: "line",
                data: { 
                    labels, 
                    datasets: [{ 
                        label: "Tokens", 
                        data: tokens, 
                        borderColor: '#f59e0b', 
                        backgroundColor: 'rgba(245, 158, 11, 0.08)', 
                        borderWidth: 2, 
                        tension: 0.4, 
                        fill: true, 
                        pointRadius: 4, 
                        pointBackgroundColor: '#f59e0b',
                        pointBorderColor: '#111827',
                        pointBorderWidth: 1
                    }] 
                },
                options: commonOptions
            });
            tokenChart = true;

            new Chart(document.getElementById("apiChart"), {
                type: "line",
                data: { 
                    labels, 
                    datasets: [{ 
                        label: "API Calls", 
                        data: apiCalls, 
                        borderColor: '#3b82f6', 
                        backgroundColor: 'rgba(59, 130, 246, 0.08)', 
                        borderWidth: 2, 
                        tension: 0.4, 
                        fill: true, 
                        pointRadius: 4, 
                        pointBackgroundColor: '#3b82f6',
                        pointBorderColor: '#111827',
                        pointBorderWidth: 1
                    }] 
                },
                options: commonOptions
            });
            apiChart = true;

            document.getElementById("latencyTime").textContent = `Updated ${formatDate(last20[last20.length - 1].timestamp)}`;
            document.getElementById("tokenTime").textContent = `Updated ${formatDate(last20[last20.length - 1].timestamp)}`;
            document.getElementById("apiTime").textContent = `Updated ${formatDate(last20[last20.length - 1].timestamp)}`;
        }

        function updateStatus(metrics) {
            if (metrics.length === 0) {
                document.getElementById("statusContainer").innerHTML = '<p style="color: #6b7280; font-size: 13px;">No data yet</p>';
                return;
            }

            const lastRun = metrics[metrics.length - 1];
            const successCount = metrics.filter(m => m.status === "success").length;
            const successRate = Math.round((successCount / metrics.length) * 100);

            const statusClass = lastRun.status === "success" ? "status-success" : "status-error";
            const statusText = lastRun.status === "success" ? "✓ Operational" : "✗ Failed";

            document.getElementById("statusContainer").innerHTML = `
                <div class="status-row">
                    <label>Latest status</label>
                    <span class="status-pill ${statusClass}">${statusText}</span>
                </div>
                <div class="status-row">
                    <label>Success rate</label>
                    <value>${successRate}%</value>
                </div>
                <div class="status-row">
                    <label>Total runs</label>
                    <value>${metrics.length}</value>
                </div>
            `;
        }

        function updateErrors(metrics) {
            const allErrors = [];
            metrics.forEach(m => {
                if (m.errors && m.errors.length > 0) {
                    m.errors.forEach(e => allErrors.push({ time: m.timestamp, error: e }));
                }
            });

            const errorLog = document.getElementById("errorLog");
            if (allErrors.length === 0) {
                errorLog.innerHTML = '<p style="color: #10b981; font-size: 12px; font-weight: 500;">No errors detected</p>';
            } else {
                errorLog.innerHTML = allErrors.slice(-5).map(e => 
                    `<div class="error-item">${formatTime(e.time)}: ${e.error}</div>`
                ).join("");
            }

            document.getElementById("errorTime").textContent = `Updated ${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
        }

        function updateLastRun(metrics) {
            if (metrics.length === 0) {
                document.getElementById("lastRunContainer").innerHTML = '<p style="color: #6b7280; font-size: 13px;">No runs yet</p>';
                return;
            }

            const lastRun = metrics[metrics.length - 1];
            document.getElementById("lastRunContainer").innerHTML = `
                <div class="status-row">
                    <label>Run ID</label>
                    <value style="font-family: monospace; font-size: 12px;">${lastRun.run_id}</value>
                </div>
                <div class="status-row">
                    <label>Timestamp</label>
                    <value>${formatDate(lastRun.timestamp)}</value>
                </div>
                <div class="status-row">
                    <label>Articles generated</label>
                    <value>${lastRun.article_count || 0}</value>
                </div>
            `;
        }

        async function refreshDashboard() {
            const metrics = await fetchMetrics();
            if (metrics.length > 0) {
                updateCharts(metrics);
                updateStatus(metrics);
                updateErrors(metrics);
                updateLastRun(metrics);
                updateTokenBudget(metrics);
            }
        }

        refreshDashboard();
        setInterval(refreshDashboard, 30000);
    </script>
</body>
</html>
